<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp"
        android:gravity="center_horizontal">

        <!-- Back Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_back_button"
                android:contentDescription="Back"
                app:tint="#FFFFFF"/>
        </LinearLayout>

        <!-- Lock Icon with glow -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_icon_glow"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🔐"
                android:textSize="44sp"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No worries! Enter your email and we'll send you a link to reset your password."
            android:textSize="14sp"
            android:textColor="#7C8DB5"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            android:paddingHorizontal="8dp"/>

        <!-- Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#111827">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Email Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textSize="13sp"
                    android:textColor="#7C8DB5"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter your email"
                    android:layout_marginBottom="28dp"
                    app:boxStrokeColor="#1E3A5F"
                    app:boxStrokeWidth="1.5dp"
                    app:boxBackgroundColor="#0D1526"
                    app:hintTextColor="#556080"
                    app:errorTextColor="#FF6B6B"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#3B82F6">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#556080"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Send Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendReset"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Send Reset Link"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#3B82F6"
                    app:cornerRadius="14dp"
                    app:elevation="0dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Success State (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="48sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset link sent!"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvSuccessEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#7C8DB5"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="16dp"/>
        </LinearLayout>

        <!-- Back to Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remember your password? "
                android:textColor="#556080"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="#3B82F6"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>