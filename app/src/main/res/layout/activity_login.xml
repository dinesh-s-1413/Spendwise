<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/bg_icon_glow"/>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"/>

        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SpendWise"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#1B4FD8"
            android:letterSpacing="0.04"
            android:fontFamily="sans-serif-medium"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart subscription tracking"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:letterSpacing="0.08"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="44dp"/>

        <!-- Login Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back 👋"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in to continue"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="28dp"/>

                <!-- Email Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email address"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="#1B4FD8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxBackgroundColor="#F8FAFF"
                    app:hintTextColor="#6B7280"
                    app:errorTextColor="#EF4444"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#1B4FD8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="#111827"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    app:boxStrokeColor="#1B4FD8"
                    app:boxStrokeWidth="1.5dp"
                    app:boxBackgroundColor="#F8FAFF"
                    app:hintTextColor="#6B7280"
                    app:errorTextColor="#EF4444"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="#1B4FD8"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#1B4FD8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="#111827"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Forgot Password -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot password?"
                    android:textColor="#1B4FD8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_gravity="end"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Sign In"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1B4FD8"
                    app:cornerRadius="14dp"
                    app:elevation="4dp"/>

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  or  "
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"/>
                </LinearLayout>

                <!-- Google Sign In Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogleSignIn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Continue with Google"
                    android:textSize="14sp"
                    android:textColor="#374151"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_google"
                    app:iconTint="@null"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Register Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New to SpendWise? "
                android:textColor="#6B7280"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create account"
                android:textColor="#1B4FD8"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>